# copy to .env, fill in, chmod 600 .env

# Telegram bot (BotFather -> /newbot -> token)
TG_BOT_TOKEN=123456:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
# chat or channel id (getUpdates after sending one message to the bot)
TG_CHAT_ID=-1001234567890

# GitHub PAT (public_repo scope is enough, lifts 60->5000 req/hr)
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NVD API key (free, lifts 5→50 req/30s): https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=

# LLM enrichment (optional, enables AI-based false positive filtering)
# DeepSeek (recommended, cheaper): https://platform.deepseek.com
# DEEPSEEK_API_KEY=
# OpenAI (alternative): https://platform.openai.com
# OPENAI_API_KEY=
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=1024
# LLM_TIMEOUT=60
# LLM_MAX_CONTEXT=8192
# LLM_REASONING_EFFORT=medium
# LLM_TOP_P=0.9

# optional outbound proxy (leave empty on US server)
# HTTPS_PROXY=http://127.0.0.1:7890
